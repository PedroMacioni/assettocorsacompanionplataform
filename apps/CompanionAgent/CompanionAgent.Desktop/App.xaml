<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CompanionAgent.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CompanionAgent.Desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Apex brand colours -->
            <Color x:Key="ApexOrange">#E8612A</Color>
            <SolidColorBrush x:Key="ApexOrangeBrush"   Color="#E8612A" />
            <SolidColorBrush x:Key="ApexSurfaceBrush"  Color="#161618" />
            <SolidColorBrush x:Key="ApexBorderBrush"   Color="#2A2A2C" />
            <SolidColorBrush x:Key="ApexMutedBrush"    Color="#6B6B72" />
            <SolidColorBrush x:Key="ApexGreenBrush"    Color="#22C55E" />
            <SolidColorBrush x:Key="ApexRedBrush"      Color="#EF4444" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
