<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="CompanionAgent.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Apex Agent">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom drag region (replaces TitleBar control — not supported in unpackaged apps) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="Transparent">
            <TextBlock Text="Apex Agent"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       FontSize="13" FontWeight="SemiBold" />
        </Grid>

        <Frame x:Name="ContentFrame" Grid.Row="1" />

        <!-- ── Update overlay ── -->
        <Grid x:Name="UpdateOverlay" Grid.Row="1" Visibility="Collapsed">

            <!-- Dim -->
            <Rectangle Fill="#D00D0D0F" />

            <!-- Card -->
            <Border CornerRadius="12" Padding="28,26"
                    MaxWidth="300" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#1A1A1C"
                    BorderBrush="#2A2A2C" BorderThickness="1">
                <StackPanel Spacing="18" HorizontalAlignment="Center">

                    <!-- Icon -->
                    <Border Width="52" Height="52" CornerRadius="26"
                            Background="#E8612A18" HorizontalAlignment="Center">
                        <SymbolIcon Symbol="Upload" Foreground="#E8612A" />
                    </Border>

                    <!-- Title + version -->
                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Text="Update available"
                                   FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="UpdateVersionLabel"
                                   Text="" FontSize="12"
                                   Foreground="#6B6B72"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Description -->
                    <TextBlock Text="A new version of Apex Agent is ready to install. Updating takes only a few seconds."
                               TextWrapping="Wrap" FontSize="12"
                               Foreground="#6B6B72" MaxWidth="230"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               LineHeight="18" />

                    <!-- Buttons -->
                    <StackPanel Spacing="8">

                        <Button x:Name="UpdateNowButton"
                                HorizontalAlignment="Stretch" Padding="0,12"
                                Click="UpdateNow_Click">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#E8612A" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#D45520" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#BF4C1C" />
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled"     Color="#7A3015" />
                                <SolidColorBrush x:Key="ButtonForeground"             Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundDisabled"     Color="#FFFFFF60" />
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ProgressRing x:Name="UpdateProgressRing"
                                              IsActive="False" Width="14" Height="14"
                                              Foreground="White" Visibility="Collapsed" />
                                <TextBlock x:Name="UpdateNowLabel"
                                           Text="Update now" FontSize="12" FontWeight="SemiBold"
                                           Foreground="White" />
                            </StackPanel>
                        </Button>

                        <Button Click="UpdateLater_Click"
                                HorizontalAlignment="Stretch" Padding="0,10">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#1E1E20" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#2A2A2C" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#333335" />
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#2A2A2C" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#333335" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="#3A3A3C" />
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#6B6B72" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#A0A0A8" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="#A0A0A8" />
                            </Button.Resources>
                            <TextBlock Text="Later" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#6B6B72" />
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
