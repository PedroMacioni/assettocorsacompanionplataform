<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CompanionAgent.Desktop.Pages.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="20,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="*" />      <!-- content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Click="Back_Click" Padding="4,4" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#2A2A2C" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#333335" />
                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                </Button.Resources>
                <SymbolIcon Symbol="Back" />
            </Button>
            <TextBlock Grid.Column="1" Text="Settings"
                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- ── CONNECTION ── -->
                <StackPanel Spacing="8">
                    <TextBlock Text="CONNECTION" FontSize="9" FontWeight="SemiBold"
                               CharacterSpacing="80" Foreground="{StaticResource ApexMutedBrush}" />

                    <Border CornerRadius="8" Padding="14"
                            Background="{StaticResource ApexSurfaceBrush}"
                            BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">

                            <!-- Connected state -->
                            <StackPanel x:Name="ConnectedSection" Spacing="10" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource ApexGreenBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Connected" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="ConnectedEmailText" Text=""
                                           FontSize="11" Foreground="{StaticResource ApexMutedBrush}" />
                                <Button Click="Disconnect_Click"
                                        HorizontalAlignment="Stretch" Padding="0,8">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground"             Color="#2A2A2C" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#3A1A1A" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#4A1A1A" />
                                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                                    </Button.Resources>
                                    <TextBlock Text="Disconnect" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource ApexRedBrush}" />
                                </Button>
                            </StackPanel>

                            <!-- Not connected state -->
                            <StackPanel x:Name="NotConnectedSection" Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource ApexMutedBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="Not connected" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource ApexMutedBrush}" />
                                </StackPanel>
                                <Button Click="Connect_Click"
                                        HorizontalAlignment="Stretch" Padding="0,9">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground"             Color="#E8612A" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#D45520" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#BF4C1C" />
                                        <SolidColorBrush x:Key="ButtonForeground"             Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White" />
                                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                                    </Button.Resources>
                                    <TextBlock Text="Connect to Apex" FontSize="12" FontWeight="SemiBold"
                                               Foreground="White" />
                                </Button>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── SYNC ── -->
                <StackPanel Spacing="8">
                    <TextBlock Text="SYNC" FontSize="9" FontWeight="SemiBold"
                               CharacterSpacing="80" Foreground="{StaticResource ApexMutedBrush}" />

                    <Border CornerRadius="8" Padding="14"
                            Background="{StaticResource ApexSurfaceBrush}"
                            BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Interval" FontSize="11"
                                       Foreground="{StaticResource ApexMutedBrush}" />
                            <ComboBox x:Name="IntervalCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="Interval_Changed">
                                <ComboBoxItem Tag="5"  Content="Every 5 minutes" />
                                <ComboBoxItem Tag="10" Content="Every 10 minutes" />
                                <ComboBoxItem Tag="15" Content="Every 15 minutes" />
                                <ComboBoxItem Tag="30" Content="Every 30 minutes" />
                                <ComboBoxItem Tag="60" Content="Every hour" />
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── DATA FOLDERS ── -->
                <StackPanel Spacing="8">
                    <TextBlock Text="DATA FOLDERS" FontSize="9" FontWeight="SemiBold"
                               CharacterSpacing="80" Foreground="{StaticResource ApexMutedBrush}" />

                    <Border CornerRadius="8" Padding="14"
                            Background="{StaticResource ApexSurfaceBrush}"
                            BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="14">

                            <!-- Sessions -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Sessions" FontSize="11"
                                           Foreground="{StaticResource ApexMutedBrush}" />
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SessionsPathBox"
                                             PlaceholderText="Default (Content Manager)"
                                             FontSize="11" TextChanged="SessionsPath_Changed" />
                                    <Button Grid.Column="1" Content="Browse"
                                            Click="BrowseSessions_Click"
                                            Padding="10,0" FontSize="11" />
                                </Grid>
                            </StackPanel>

                            <!-- Personal bests -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Personal bests (.ini)" FontSize="11"
                                           Foreground="{StaticResource ApexMutedBrush}" />
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PbPathBox"
                                             PlaceholderText="Default (My Documents\Assetto Corsa)"
                                             FontSize="11" TextChanged="PbPath_Changed" />
                                    <Button Grid.Column="1" Content="Browse"
                                            Click="BrowsePb_Click"
                                            Padding="10,0" FontSize="11" />
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="Changes to folders take effect on the next app restart."
                                       FontSize="10" Foreground="{StaticResource ApexMutedBrush}"
                                       Opacity="0.6" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── GENERAL ── -->
                <StackPanel Spacing="8">
                    <TextBlock Text="GENERAL" FontSize="9" FontWeight="SemiBold"
                               CharacterSpacing="80" Foreground="{StaticResource ApexMutedBrush}" />

                    <Border CornerRadius="8" Padding="14"
                            Background="{StaticResource ApexSurfaceBrush}"
                            BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Launch agent automatically on login"
                                           FontSize="10" Foreground="{StaticResource ApexMutedBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoStartToggle" Grid.Column="1"
                                          OnContent="" OffContent=""
                                          Toggled="AutoStart_Toggled"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Rectangle Height="8" />

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
