<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CompanionAgent.Desktop.Pages.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="20,16" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- back + title -->
            <RowDefinition Height="*" />     <!-- state panels -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Click="Back_Click" Padding="4,4" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#2A2A2C" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#333335" />
                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                </Button.Resources>
                <SymbolIcon Symbol="Back" />
            </Button>

            <TextBlock Grid.Column="1" Text="Connection"
                       FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <!-- State panels -->
        <Grid Grid.Row="1">

            <!-- ── Not connected ── -->
            <StackPanel x:Name="NotConnectedPanel" Spacing="20" VerticalAlignment="Top">

                <Border CornerRadius="8" Padding="16"
                        Background="{StaticResource ApexSurfaceBrush}"
                        BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{StaticResource ApexMutedBrush}"
                               Text="A browser window will open so you can approve the connection from your Apex account." />
                </Border>

                <TextBlock x:Name="ErrorText" Visibility="Collapsed"
                           Foreground="{StaticResource ApexRedBrush}"
                           TextWrapping="Wrap" FontSize="12" />

                <Button x:Name="ConnectButton"
                        HorizontalAlignment="Stretch" Padding="0,10"
                        Click="Connect_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground"             Color="#E8612A" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#D45520" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#BF4C1C" />
                        <SolidColorBrush x:Key="ButtonBackgroundDisabled"     Color="#7A3015" />
                        <SolidColorBrush x:Key="ButtonForeground"             Color="White" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White" />
                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                    </Button.Resources>
                    <TextBlock Text="Connect to Apex" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                </Button>
            </StackPanel>

            <!-- ── Waiting for browser approval ── -->
            <StackPanel x:Name="WaitingPanel" Visibility="Collapsed" Spacing="20" VerticalAlignment="Top">

                <Border CornerRadius="8" Padding="16"
                        Background="{StaticResource ApexSurfaceBrush}"
                        BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <ProgressRing IsActive="True" Width="18" Height="18"
                                          Foreground="{StaticResource ApexOrangeBrush}" />
                            <TextBlock x:Name="WaitingText" Text="Opening browser…"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource ApexMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Content="Cancel" Click="CancelPairing_Click"
                        HorizontalAlignment="Stretch" Padding="0,8">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground"             Color="#2A2A2C" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#333335" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#3A3A3C" />
                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- ── Connected ── -->
            <StackPanel x:Name="ConnectedPanel" Visibility="Collapsed" Spacing="16" VerticalAlignment="Top">

                <!-- Status badge -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource ApexGreenBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="Connected" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Account card -->
                <Border CornerRadius="8" Padding="16"
                        Background="{StaticResource ApexSurfaceBrush}"
                        BorderBrush="{StaticResource ApexBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="ACCOUNT" FontSize="9" FontWeight="SemiBold"
                                   CharacterSpacing="80"
                                   Foreground="{StaticResource ApexMutedBrush}" />
                        <TextBlock x:Name="AccountEmail" Text="—"
                                   FontSize="14" FontWeight="SemiBold" />
                        <TextBlock x:Name="AccountId" Text="—" FontSize="11"
                                   Foreground="{StaticResource ApexMutedBrush}" />
                    </StackPanel>
                </Border>

                <!-- Disconnect -->
                <Button Click="Disconnect_Click"
                        HorizontalAlignment="Stretch" Padding="0,8">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground"             Color="#2A2A2C" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#3A1A1A" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#4A1A1A" />
                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonForeground"             Color="#EF4444" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#EF4444" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="#EF4444" />
                    </Button.Resources>
                    <TextBlock Text="Disconnect" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource ApexRedBrush}" />
                </Button>

            </StackPanel>

        </Grid>
    </Grid>
</Page>
