<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CompanionAgent.Desktop.Pages.DataSourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="40,32">
        <StackPanel Spacing="24" MaxWidth="680" HorizontalAlignment="Left">

            <TextBlock Text="Data Sources" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Assetto Corsa folder -->
            <Border CornerRadius="8" Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Assetto Corsa" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Sessions and setups folder" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AcFolderBox" Grid.Column="0"
                                 PlaceholderText="C:\Users\…\Documents\Assetto Corsa"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse" Click="BrowseAcFolder_Click" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
