<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CompanionAgent.Desktop.Pages.LoadingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">

            <!-- Icon -->
            <Border Width="56" Height="56" CornerRadius="28"
                    Background="#E8612A18" HorizontalAlignment="Center">
                <SymbolIcon Symbol="Globe" Foreground="#E8612A" />
            </Border>

            <!-- App name -->
            <TextBlock Text="Apex Agent"
                       FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <!-- Spinner + status -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <ProgressRing IsActive="True" Width="24" Height="24"
                              Foreground="#E8612A" HorizontalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="Starting…"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="{StaticResource ApexMutedBrush}" />
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
