<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CompanionAgent.Desktop.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="Activity" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Content="Clear" Click="Clear_Click" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="LogList" Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
